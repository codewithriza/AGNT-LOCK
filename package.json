{
  "name": "agnt-lock",
  "version": "1.0.0",
  "description": "MCP coordination layer that prevents AI agents from overwriting each other's work in shared repositories",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agnt-lock": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "coordination",
    "lock-manager",
    "claude",
    "cursor",
    "aider",
    "roo-code",
    "multi-agent"
  ],
  "author": "Riza Mohamed T",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithriza/AGNT-LOCK.git"
  },
  "bugs": {
    "url": "https://github.com/codewithriza/AGNT-LOCK/issues"
  },
  "homepage": "https://github.com/codewithriza/AGNT-LOCK#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
